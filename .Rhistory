# Random Forest
myrandomforest_neg_mode <- perform_RandomForest(
prepped_data  = df_prepped_neg_mode,
outcome_var   = "Group",
features      = ennet_features,
data_type     = "NONPLS",
use_merged    = FALSE,
ntree         = 1000,
mtry          = NULL,
optimize_mtry = TRUE,
mtry_range    = 1:10,
seed          = 123,
proximity     = TRUE
)
# SVM
mysvm_neg_mode <- perform_SVM(
prepped_data  = df_prepped_neg_mode,
outcome_var   = "Group",
features      = ennet_features,
data_type     = "NONPLS",
use_merged    = FALSE,
kernel        = "radial",
tune_params   = TRUE,
cost          = c(0.01, 0.1, 1, 10, 100),
gamma         = NULL,
degree        = c(2, 3, 4),
cross         = 10,
probability   = TRUE,
seed          = 123
)
# Adaptive Boost
myadaboost_neg_mode <- perform_AdaBoost(
prepped_data = df_prepped_neg_mode,
outcome_var  = "Group",
features     = ennet_features,
data_type    = "NONPLS",
use_merged   = FALSE,
tune_mfinal  = TRUE,
mfinal       = c(50, 100, 150, 200),
cross        = 10,
maxdepth     = 1,
coeflearn    = "Breiman",
seed         = 42
)
# LDA
mylda_neg_mode <- perform_LDA(
prepped_data           = df_prepped_neg_mode,
outcome_var            = "Group",
features               = ennet_features,
data_type              = "NONPLS",
use_merged             = FALSE,
prior                  = "auto",
pca_preprocess         = TRUE,
pca_variance_threshold = 0.95,
cv_method              = "cv",
cross                  = 10,
repeats                = 3,
tol                    = 1e-04,
seed                   = 42
)
# KNN
myknn_neg_mode <- perform_KNN(
prepped_data = df_prepped_neg_mode,
outcome_var  = "Group",
features     = ennet_features,
data_type    = "NONPLS",
use_merged   = FALSE,
tune_k       = TRUE,
k            = seq(1, 21, by = 2),
distance     = 2,
kernel       = "optimal",
cv_method    = "cv",
cross        = 10,
repeats      = 3,
seed         = 123
)
# Decision Tree
mydecisiontree_neg_mode <- perform_DT(
prepped_data      = df_prepped_neg_mode,
outcome_var       = "Group",
features          = ennet_features,
data_type         = "NONPLS",
use_merged        = FALSE,
tune_mincriterion = TRUE,
mincriterion      = c(0.75, 0.85, 0.9, 0.95, 0.99),
cross             = 10,
minsplit          = 20,
minbucket         = 7,
seed              = 123
)
# Model evaluation
mymodelevaluation_neg_mode <- perform_ModelEvaluation(
myrandomforest_neg_mode, mysvm_neg_mode, myadaboost_neg_mode,
myknn_neg_mode, mydecisiontree_neg_mode, mylda_neg_mode,
model_names   = NULL,
compute_shap  = TRUE,
shap_nsim     = 100,
shap_bg_n     = 50,
shap_type     = "both",
seed          = 42
)
